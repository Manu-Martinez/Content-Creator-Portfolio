---
const base = import.meta.env.BASE_URL;

const tools = [
    { name: "Premiere Pro",   icon: `${base}/icons/premiere.svg`,     color: "#9999FF" },
    { name: "After Effects",  icon: `${base}/icons/aftereffects.svg`,  color: "#9999FF" },
    { name: "Photoshop",      icon: `${base}/icons/photoshop.svg`,     color: "#31A8FF" },
    { name: "DaVinci Resolve",icon: `${base}/icons/davinci.svg`,       color: "#F6BE00" },
    { name: "CapCut",         icon: `${base}/icons/capcut.svg`,        color: "#ffffff" },
    { name: "Audacity",       icon: `${base}/icons/audacity.svg`,     color: "#4D9EFF" },
];
---


<section id="tools" class="tools-section">
     <h3>Herramientas</h3>
    <div class="tools-container">
        {tools.map((tool) => (
            <div class="tool-card" style={`--tool-color: ${tool.color}`}>
                <img src={tool.icon} alt={tool.name} class="tool-icon" />
                <span>{tool.name}</span>
            </div>
        ))}
    </div>
</section>
