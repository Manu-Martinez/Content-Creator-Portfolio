---
import MainLayout from '../layouts/MainLayout.astro';
import Tools from '../components/Tools.astro';
import Portfolio from '../components/Portfolio.astro';

// LISTA DE VIDEOS (Agrega aquí todos los que quieras)
const verticalVideos = [
    { id: 'SOVPB-obdvM', title: 'Group B de rally - Potencia y Peligro' },
    { id: 'CsuTlhaIEcQ', title: 'Prueba de edición 7: The Circel of Drift entrevista' },
    { id: 'Rl0pl9a4NyI', title: 'Prueba de edición de video 2: Publicidad Falsa' },
	{ id: 'Tw66S8UnYG8', title: 'Prueba de edición 9: Gameplay Short' },
	{ id: '4FsTK93foaA', title: '(Franmentor 2)🍺🍺 Catando HyperViolent(Short 2)' },
];

const horizontalVideos = [
    { id: '3C9AzuzxMYs', title: 'Al Agua Pato - Cortometraje (Corte final)' },
    { id: 'ZV95iNLEexM', title: 'Prueba edición de video 4: Video musical' },
    { id: 'J0_c82HLznY', title: 'Prueba edición Motion Graphics CBX 1000' },
	{ id: 'Uf9ZFxlDy9A', title: '(Oboeshoestwos) Elden Ring meets WW1 in TRENCH TALES (Highlight edit)' },
	{ id: 'Y3YFrWSE9EI', title: '(Recorte FranMentor) 🍺🍺Catando HyperViolent' },
];
---



<MainLayout title="Productor Audiovisual | Portafolio">
    
    <section class="hero">
        <div class="profile-img">
            <img src="/foto-perfil.jpg" alt="Productor">
        </div>
        <h1>Darío Alberto Martínez</h1>
        <p class="description">Especialista en narrativa visual y edición de alto impacto.</p>
    </section>

	<!-- SECCIÓN CV (Debajo del About Me) -->
<section class="cv-section">
    <p>¿Quieres ver mi trayectoria completa?</p>
    <a href="/tu-cv.pdf" download class="btn-cv">
        <span>📄</span> Descargar Currículum Vitae
    </a>
</section>

    <hr>

    <Tools />

    <Portfolio>
       <!-- VIDEOS VERTICALES -->
{verticalVideos.map((video) => (
    <div slot="shorts" class="video-placeholder">
        <div class="v-card">
            <iframe 
                src={`https://www.youtube.com/embed/${video.id}`}
                title={video.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen
                loading="lazy">
            </iframe>
        </div>
    </div>
))}

<!-- VIDEOS HORIZONTALES -->
{horizontalVideos.map((video) => (
    <div slot="longs" class="video-placeholder">
        <div class="h-card">
            <iframe 
                src={`https://www.youtube.com/embed/${video.id}`}
                title={video.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen
                loading="lazy">
            </iframe>
        </div>
    </div>
))}
    </Portfolio>

    <section id="contact" class="contact-form">
        <h3>¿Tienes un proyecto?</h3>
        <form>
            <input type="text" placeholder="Nombre" required />
            <input type="email" placeholder="Email" required />
            <textarea placeholder="Mensaje..." rows="4"></textarea>
            <button type="submit" class="btn-grad">Enviar Mensaje</button>
        </form>
    </section>

	<!-- Redes Sociales en el Hero -->
    <div class="social-links">
        <a href="https://linkedin.com..." target="_blank" class="social-tag">LinkedIn</a>
        <a href="https://youtube.com..." target="_blank" class="social-tag yt">YouTube</a>
    </div>
</section>

</MainLayout>

