---
import MainLayout from '../layouts/MainLayout.astro';
import Tools from '../components/Tools.astro';
import Portfolio from '../components/Portfolio.astro';
---

<MainLayout title="Productor Audiovisual | Portafolio">
    
    <section class="hero">
        <div class="profile-img">
            <img src="/foto-perfil.jpg" alt="Productor">
        </div>
        <h1>Nombre del Productor</h1>
        <p class="description">Especialista en narrativa visual y edición de alto impacto.</p>
    </section>

	<!-- SECCIÓN CV (Debajo del About Me) -->
<section class="cv-section">
    <p>¿Quieres ver mi trayectoria completa?</p>
    <a href="/tu-cv.pdf" download class="btn-cv">
        <span>📄</span> Descargar Currículum Vitae
    </a>
</section>

    <hr>

    <Tools />

    <Portfolio>
        <div slot="shorts" class="video-placeholder v-card">Short 1</div>
        <div slot="shorts" class="video-placeholder v-card">Short 2</div>
        <!-- ... más videos ... -->
        
        <div slot="longs" class="video-placeholder h-card">Video Largo 1</div>
        <div slot="longs" class="video-placeholder h-card">Video Largo 2</div>
    </Portfolio>

    <section id="contact" class="contact-form">
        <h3>¿Tienes un proyecto?</h3>
        <form>
            <input type="text" placeholder="Nombre" required />
            <input type="email" placeholder="Email" required />
            <textarea placeholder="Mensaje..." rows="4"></textarea>
            <button type="submit" class="btn-grad">Enviar Mensaje</button>
        </form>
    </section>

	<!-- Redes Sociales en el Hero -->
    <div class="social-links">
        <a href="https://linkedin.com..." target="_blank" class="social-tag">LinkedIn</a>
        <a href="https://youtube.com..." target="_blank" class="social-tag yt">YouTube</a>
    </div>
</section>

</MainLayout>

